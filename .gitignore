# ============================================================
# .gitignore — Files Git should NEVER track or upload
# ============================================================

# --- Environment variables (contains your secret API key!) ---
.env

# --- Node.js dependencies (reinstall with: npm install) ---
node_modules/

# --- macOS system files ---
.DS_Store

# --- Windows system files ---
Thumbs.db
desktop.ini

# --- Editor/IDE config ---
.vscode/
.idea/

# --- Logs ---
*.log
npm-debug.log*
